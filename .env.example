HOST="https://refine.yourdomain.com"
ADMIN_TOKEN="change-me"
ENCRYPTION_KEY="change-me-32-chars-min"

# Auto-delete history older than N days (0 or unset = keep forever):
# HISTORY_RETENTION_DAYS="90"

# Local SQLite (default for Docker / self-hosted):
DATABASE_URL="file:/data/refine.db"

# Remote libsql / Turso (optional — omit for local file):
# DATABASE_URL="libsql://your-db.turso.io"
# TURSO_AUTH_TOKEN="your-turso-auth-token"
